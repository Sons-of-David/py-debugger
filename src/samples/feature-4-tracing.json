{
  "userCode": "# ── Tracing Variables Demo ────────────────────────────────────────────────────\n# Two ways to bind visual elements to algorithm variables at each traced step:\n#\n#   1. V('expr') — evaluates the expression at each timeline step.\n#      Must be assigned directly to a shape property:\n#        rect.width = V('i')       ✓\n#        rect.width = 1 + V('i')   ✗  — use V('1+i') instead\n#      Optional: default=<value> for steps where expr is undefined.\n#\n#   2. viz blocks — wrap mutations in # @viz ... # @end to record a snapshot.\n#      Any V() change outside a viz block also triggers a snapshot automatically.\n#\n# ─────────────────────────────────────────────────────────────────────────────\n\n# Find Array Maximum — algorithm traced by this example.\n# Press Analyze, then step through the timeline.\n\narr = [1,5,4,7,9,3,5,2]\nindex_max = 0\n\n# @viz\npanel = Panel(x=1, y=1)\n\npanel.add(\n    Array(cells=V('arr'), x=0, y=1),\n    # i is undefined at this point, so a default value is provided.\n    # Alternative: add 'i = 0' before this viz block.\n    Arrow(angle=Arrow.DOWN, x=V('i', default=0), color=(230,70,80)),\n    Rect(x=V('index_max'), y=1, alpha=0.6),\n    \n)\n\nlabel = Label(label=V('current max'), x=2, y=2, width=4)\npanel.add(label)\n\n# @end\n\ndef print_result():\n    print(f'max value is {arr[index_max]=}')\n\nfor i in range(len(arr)):\n    if arr[index_max] < arr[i]:\n        index_max = i\n        # @viz\n        label.label = f'current max: {arr[i]}'\n        # @end\n\nprint_result()\n",
