  "userCode": "\narr = [0, 2, 3, 4, 2, 1, 3, 2, 5, 6]\nn = len(arr)\n\ns = 6\nstart = 0\nend = 0\ncur_sum = 0\n\n# @viz\n\nprefix_sum = [0]\nfor elem in arr:\n    prefix_sum.append(prefix_sum[-1]+elem)\n\npanel = Panel(x=2, y=2)\n\npanel.add(\n    Array(cells=arr, x=1),\n    Rect(x=V('start+1'), width=V('end-start'), alpha=0.3),\n    Label(label=V('f\"{sum(arr[start:end])} ? {s}\"'), y=1, x=V('start'), width=3)\n)\n\npanel2d = Panel(x=0, y=3)\npanel.add(panel2d)\npanel2d.add(Circle(x=V('end'), y=V('start')))\n\nfor i in range(n+1):\n    for j in range(i, n+1):\n        cell_value = prefix_sum[j]-prefix_sum[i]\n        color = (200, 50, 80)\n        if cell_value == s:\n            color = (50, 80, 200)\n        if cell_value > s:\n            color = (80, 200, 50)\n        panel2d.add(\n            Label(label=cell_value, x=j, y=i, color=color, font_size=20)\n        )\n\n# @end\n\n\nwhile end <= n:\n    if start == end:\n        if end == n:\n            break\n        cur_sum += arr[end]\n        end += 1\n        continue\n\n    if cur_sum < s:\n        if end == n:\n            break\n        cur_sum += arr[end]\n        end += 1\n        continue\n\n    if cur_sum > s:\n        cur_sum -= arr[start]\n        start += 1\n        continue\n\n    print(f'found arr[{start}:{end}]')\n    cur_sum -= arr[start]\n    start += 1\n    continue\n",
