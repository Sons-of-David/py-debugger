  "userCode": "arr = [5, 7, 2, 6, 3, 1]\nmin_index = 0\nj = 0\n\n# @viz\nclass LabeledArrow(Panel):\n    def __init__(self, label: str, color: tuple[int, int, int], **kwargs):\n        super().__init__(**kwargs)\n        self.add(\n            Arrow(angle=Arrow.DOWN, color=color, x=0, y=1),\n            Label(label=label, color=color)\n        )\n\npanel = Panel(x=2, y=2)\npanel.add(\n    Array(cells=arr),\n    Rect(width=V(\"i\", default=0), alpha=0.7),\n    LabeledArrow(label='index min', color=(220, 70, 120), x=V('min_index'), y=-2),\n    LabeledArrow(label='j', color=(120, 70, 220), x=V('j'), y=-2)\n)\n# @end\n\nn = len(arr)\n\nfor i in range(n):\n    min_index = i\n\n    for j in range(i + 1, n):\n        if arr[j] < arr[min_index]:\n            min_index = j\n\n    arr[i], arr[min_index] = arr[min_index], arr[i]\n",
