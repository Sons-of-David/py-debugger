{
  "userCode": "# Fibonacci / domino tiling — f(n) = f(n-1) + f(n-2).\n# Press Analyze, then step through the timeline to watch the recursion unfold.\n# Look at the visual builder editor for more details.\n\nn = 5\n\n# @viz\nRECT_COLOR = (128, 26, 134)\nCIRCLE_COLOR = (143, 227, 136)\n\npanel = Panel(x=1, y=1)\ncounter_label = Label(x=1, y=3, width=3)\npanel.add(Rect(width=n, height=2, color=RECT_COLOR), counter_label)\ndominoes = []\ndominoes_x = 0    \ncounter = 0\n# @end\n\n\ndef fib(n: int) -> int:\n    if n <= 0:\n        print('Empty Board!')\n        # @viz\n        global counter\n        counter +=1 \n        counter_label.label=f'counted {counter}'\n        # @end\n        return 1 # One (empty) way to fill an empty board\n\n    # Either remove 1 and compute the rest:\n    # @viz\n    global dominoes_x\n    dominoes.append(Circle(height=2, x=dominoes_x, color=CIRCLE_COLOR))\n    panel.add(dominoes[-1])\n    dominoes_x+=1\n    # @end\n    res = fib(n-1)\n    # @viz\n    dominoes.pop().delete()\n    dominoes_x-=1\n    # @end\n    # Or remove 2 (if possible) and compute the rest:\n    if n >= 2:\n        # @viz\n        dominoes.append(Circle(width=2, x=dominoes_x, color=CIRCLE_COLOR))\n        dominoes.append(Circle(width=2, x=dominoes_x, y=1, color=CIRCLE_COLOR))\n        panel.add(dominoes[-1], dominoes[-2])\n        dominoes_x+=2\n        # @end\n        res += fib(n-2)\n        # @viz\n        dominoes.pop().delete()\n        dominoes.pop().delete()\n        dominoes_x-=2\n        # @end\n        \n    return res\n\nresult = fib(n)\nprint(result)\n# @viz\ncounter_label.label = f'Fib({n})={result}'\n# @end",
