        "id": "tab-1",
        "name": "main",
        "code": "# \u2500\u2500 Strongly Connected Components \u2014 Tarjan's algorithm \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Interactive mode. Click Analyze, then press SCC.\n#\n#  \u2022 SCC button      \u2192 single DFS with low-link values\n#  \u2022 Node label: discovery_time, low_link\n#  \u2022 When low == discovery the node is an SCC root; pop the stack\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n# @viz\ndef create_graph():\n\tgraph = Graph()\n \n\tnodes_info=[None, None, None, None, None, None, None, None, None, None, None]\n\tnodes = [graph.add_node(info) for info in nodes_info]\n \n\tpositions = [(3,3), (3,6), (3,9), (7,12), (3,12), (7,9), (12,9), (9,6), (12,6), (9,3), (6,3)]\n\tfor node, position in zip(nodes, positions):\n\t\tnode._viz.x, node._viz.y = position\n        \n\tconnections = [(0,1),(1,2),(2,3),(3,4),(4,2),(2,5),(5,3),(5,6),(1,7),(7,8),(8,6),(7,9),(0,10),(10,9)]\n\tedge_info =[None,None,None,None,None,None,None,None,None,None,None,None,None,None]\n\tfor (i,j), info in zip(connections, edge_info):\n\t\tedge = graph.add_edge(nodes[i], nodes[j], info)\n\t\tedge._viz.set_start(nodes[i]._viz.x, nodes[i]._viz.y)\n\t\tedge._viz.set_end(nodes[j]._viz.x, nodes[j]._viz.y)\n \n\treturn graph\n\nbuttons_panel = create_buttons()\n\nrun_dfs_btn = LabeledRect(label='SCC', x=9)\nrun_dfs_btn.rect.on_click = lambda x, y: dfs_conn_comp(graph)\nbuttons_panel.add(run_dfs_btn)\n            \ngraph = no_debug(create_graph)()\n\nEDGE_SUPER_COLOR     = ( 160, 70, 120)\n\nno_trace()\n# @end\n\n\ndef dfs_conn_comp(graph: Graph):\n    v_time = dict()\n    v_low = dict()\n    time = [0]\n    stack = []\n\n    def _dfs(node: Node, parent_edge: Edge | None):\n        if node in v_time:\n            # @viz\n            dfs_arrow.x = node._viz.x+1\n            dfs_arrow.y = node._viz.y+1\n\n            if parent_edge is not None:\n                parent_edge._viz.set_color(EDGE_VISIT_COLOR)\n            # @end\n            return\n        stack.append(node)\n        v_low[node] = time[0]\n        v_time[node] = time[0]\n        time[0] += 1\n        # @viz\n        dfs_arrow.x = node._viz.x+1\n        dfs_arrow.y = node._viz.y+1\n\n        node._viz.set_label(f'{v_time[node]},{v_low[node]}')\n        node._viz.set_color(NODE_VISIT_COLOR)\n\n        if parent_edge is not None:\n            parent_edge._viz.set_color(EDGE_VISIT_COLOR)\n        # @end\n\n        for edge in node.outgoing:\n            _dfs(edge.to_node, edge)        \n            v_low[node] = min(v_low[node], v_low[edge.to_node])\n            # @viz  \n            dfs_arrow.x = node._viz.x+1\n            dfs_arrow.y=node._viz.y+1\n            node._viz.set_label(f'{v_time[node]},{v_low[node]}')\n\n            if v_low[node] < v_low[edge.to_node]:\n                edge._viz.set_color(EDGE_SUPER_COLOR)\n            else:\n                edge._viz.set_color(EDGE_FINISH_COLOR)\n            # @end        \n\n        if v_low[node] == v_time[node]:\n            component = []\n            while len(stack) > 0:\n                v = stack.pop()\n                component.append(v)\n                # @viz\n                v._viz.set_color(NODE_FINISH_COLOR)\n                # @end\n                if v == node:\n                    break\n    \n    # @viz\n    dfs_arrow = Arrow(angle=-45)\n    no_trace()\n    # @end\n    for v in graph.nodes:\n        _dfs(v, None)\n    # @viz\n    dfs_arrow.delete()\n    # @end\n\n\n\n    \n\n\n"
      },
