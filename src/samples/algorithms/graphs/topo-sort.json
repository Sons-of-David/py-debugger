      {
        "id": "tab-1",
        "name": "main",
        "code": "# \u2500\u2500 Topological Sort \u2014 Kahn's BFS algorithm \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Interactive mode. Click Analyze, then press Topo Scan.\n#\n#  \u2022 Topo Scan button \u2192 Kahn's: process zero-in-degree nodes first\n#  \u2022 Node label: current in-degree \u2192 #position when processed\n#  \u2022 Prints 'The graph has cycles' if the ordering is incomplete\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n# Creating the graph in visual mode\n\n# @viz\n\ndef create_graph():\n\tgraph = Graph()\n \n\tnodes_info=[None, None, None, None, None, None, None, None, None, None, None, None, None, None, None]\n\tnodes = [graph.add_node(info) for info in nodes_info]\n \n\tpositions = [(11,12), (7,9), (15,13), (15,9), (7,3), (11,3), (11,6), (3,9), (15,6), (19,13), (15,3), (19,9), (19,6), (19,3), (22,9)]\n\tfor node, position in zip(nodes, positions):\n\t\tnode._viz.x, node._viz.y = position\n        \n\tconnections = [(0,1),(0,2),(0,3),(4,1),(4,5),(5,6),(1,7),(3,8),(2,9),(8,6),(8,10),(9,11),(8,12),(12,11),(12,13),(13,10),(11,14),(3,1)]\n\tedge_info =[None,None,None,None,None,None,None,None,None,None,None,None,None,None,None,None,None,None]\n\tfor (i,j), info in zip(connections, edge_info):\n\t\tedge = graph.add_edge(nodes[i], nodes[j], info)\n\t\tedge._viz.set_start(nodes[i]._viz.x, nodes[i]._viz.y)\n\t\tedge._viz.set_end(nodes[j]._viz.x, nodes[j]._viz.y)\n \n\treturn graph\n\ngraph = no_debug(create_graph)()\nscanner_arrow = Arrow(x=0, y=0, angle=-45, alpha=0)\nno_trace()\n# @end\n\nfrom collections import deque\n\nclass TopoScanner:\n    def __init__(self, graph: Graph):\n        self.graph = graph\n\n    def run(self):\n\n        node_in_deg = {node: len(node.ingoing) for node in self.graph.nodes}\n        q = deque([node for node, count in node_in_deg.items() if count == 0])\n        # @viz\n        for edge in graph.edges:\n            edge._viz.set_color(EDGE_BASE_COLOR)\n        for node, count in node_in_deg.items():\n            node._viz.set_label(count)\n            node._viz.set_color(NODE_VISIT_COLOR)\n        # @end\n        \n        order = []\n        while len(q) > 0:\n            node = q.popleft()\n            # @viz\n            scanner_arrow.x = node._viz.x+1\n            scanner_arrow.y = node._viz.y+1\n            scanner_arrow.alpha = 1\n            # @end\n\n            for edge in node.outgoing:\n                to_node = edge.to_node\n                node_in_deg[to_node] -= 1\n                # @viz\n                edge._viz.set_color(EDGE_FINISH_COLOR)\n                to_node._viz.set_label(node_in_deg[to_node])\n                # @end\n                if node_in_deg[to_node] == 0:\n                    q.append(to_node)\n            \n            order.append(node)\n            # @viz\n            node._viz.set_color(NODE_FINISH_COLOR)\n            node._viz.set_label(f'#{len(order)}')\n            # @end\n\n        # @viz\n        scanner_arrow.alpha = 0\n        no_trace()\n        # @end\n        if len(order)<len(graph.nodes):\n            print('The graph has cycles')\n            \n\nscanner = no_debug(TopoScanner)(graph)\n\n\n# @viz\nbuttons_panel = create_buttons()\n\ntopo_scan_btn = LabeledRect(label='Topo Scan', x=9)\nbuttons_panel.add(topo_scan_btn)\ndef topo_scan():\n    scanner.run()\ntopo_scan_btn.rect.on_click = lambda x, y: topo_scan()\n\nno_trace()\n# @end\n\n\n    \n\n\n"
      },
