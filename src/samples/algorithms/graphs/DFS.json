      {
        "id": "tab-1",
        "name": "main",
        "code": "# \u2500\u2500 Depth-First Search \u2014 directed graph traversal with timestamps \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Interactive mode. Click Analyze, then click a node to run DFS from it.\n#\n#  \u2022 Click a node    \u2192 DFS from that node (node label: entry:exit time)\n#  \u2022 Reset DFS btn   \u2192 clear all timestamps and colors; pick a new root\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n# Creating the graph in visual mode\n\n# @viz\n\ndef create_graph():\n\tgraph = Graph()\n \n\tnodes_info=[None, None, None, None, None, None, None, None, None, None, None]\n\tnodes = [graph.add_node(info) for info in nodes_info]\n \n\tpositions = [(3,3), (3,6), (3,9), (7,12), (3,12), (7,9), (12,9), (9,6), (12,6), (9,3), (6,3)]\n\tfor node, position in zip(nodes, positions):\n\t\tnode._viz.x, node._viz.y = position\n        \n\tconnections = [(0,1),(1,2),(2,3),(3,4),(4,2),(2,5),(5,3),(5,6),(1,7),(7,8),(8,6),(7,9),(0,10),(10,9)]\n\tedge_info =[None,None,None,None,None,None,None,None,None,None,None,None,None,None]\n\tfor (i,j), info in zip(connections, edge_info):\n\t\tedge = graph.add_edge(nodes[i], nodes[j], info)\n\t\tedge._viz.set_start(nodes[i]._viz.x, nodes[i]._viz.y)\n\t\tedge._viz.set_end(nodes[j]._viz.x, nodes[j]._viz.y)\n \n\treturn graph\n\ngraph = no_debug(create_graph)()\nno_trace()\n# @end\n\nclass DFSScanner:\n    def __init__(self, graph: Graph):\n        self.graph = graph\n        self.restart_dfs()\n\n    def restart_dfs(self):\n        self.dfs_visited = [False] * len(self.graph.nodes)\n        # @viz\n        for node in self.graph.nodes:\n            node._viz.set_color(NODE_BASE_COLOR)\n            node._viz.set_label('')\n        for edge in self.graph.edges:\n            edge._viz.set_color(EDGE_BASE_COLOR)\n        # @end\n\n    def run(self, root: Node):\n        if self.dfs_visited[root.index]:\n            return\n\n        def _dfs(node: Node, parent_edge: Edge | None):\n            if self.dfs_visited[node.index]:\n                # @viz\n                dfs_arrow.x, dfs_arrow.y = node._viz.x+1, node._viz.y+1\n                if parent_edge is not None:\n                    parent_edge._viz.set_color(EDGE_UNUSED_COLOR)\n                # @end\n                return\n            # @viz\n            dfs_arrow.x, dfs_arrow.y = node._viz.x+1, node._viz.y+1\n            node._viz.set_color(NODE_VISIT_COLOR)\n            cur_time = dfs_time[0]\n            dfs_time[0] += 1\n            node._viz.set_label(cur_time)\n            if parent_edge is not None:\n                parent_edge._viz.set_color(EDGE_VISIT_COLOR)\n            # @end\n            self.dfs_visited[node.index] = True\n            for edge in node.outgoing:\n                _dfs(edge.to_node, edge)\n                # @viz\n                dfs_arrow.x, dfs_arrow.y = node._viz.x+1, node._viz.y+1\n                # @end\n            # @viz\n            node._viz.set_color(NODE_FINISH_COLOR)\n            if parent_edge is not None:\n                parent_edge._viz.set_color(EDGE_FINISH_COLOR)\n\n            node._viz.set_label(f'{cur_time}:{dfs_time[0]}')\n            dfs_time[0] += 1\n            # @end\n        \n        # @viz\n        dfs_time = [0]\n        dfs_arrow = Arrow(x=root._viz.x+1, y=root._viz.y+1, angle=-45)\n        # @end\n        _dfs(root, None)\n        # @viz\n        dfs_arrow.delete()\n        # @end\n\nscanner = no_debug(DFSScanner)(graph)\n\n# @viz\n\ndef dfs_click(node: Node, x: int, y: int):\n    scanner.run(node)\n    return True\n\nVizNode.click_handlers.insert(0, dfs_click)\n\n# ----------------- Buttons -----------------\n\nbuttons_panel = create_buttons()\n\nrun_dfs_btn = LabeledRect(label='Reset DFS', x=9)\ndef start_dfs():\n    no_debug(scanner.restart_dfs)()\nrun_dfs_btn.rect.on_click = lambda x, y: start_dfs()\n\nbuttons_panel.add(run_dfs_btn)\n\nno_trace()\n# @end\n\n\n\n    \n\n\n"
      },
