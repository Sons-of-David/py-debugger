# Send Feedback → creates GitHub issues via api/feedback (Vercel) or Vite dev middleware.
# Copy to `.env.local` and fill in. Never commit real tokens.
#
# Token: https://github.com/settings/personal-access-tokens (fine-grained) or
#        https://github.com/settings/tokens (classic). Needs permission to open issues on the repo.
# This project’s issues repo: https://github.com/tamird14/py-debugger

GITHUB_TOKEN=
GITHUB_REPO_OWNER=tamird14
GITHUB_REPO_NAME=py-debugger
